      <aliases enabled='yes' />
      <column caption='Liquidity Buffer (Months)' datatype='real' name='[Calculation_0347477220900864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12)' />
      </column>
      <column caption='Delinquency Flag (Numeric)' datatype='integer' name='[Calculation_0347477244682243]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([DelinquencyFlag])' />
      </column>
      <column caption='Relative Delinquency Index' datatype='real' name='[Calculation_0347477257351172]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_6729592197292044]&#10;/&#10;TOTAL([Calculation_6729592197292044])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='% of Mortgage Portfolio Balance' datatype='real' name='[Calculation_0347477334675470]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Home loan Balance]) / TOTAL(SUM([Home loan Balance]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Leverage Level' datatype='string' name='[Calculation_0347477378277392]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_6729592193171463] &lt; 3 THEN &quot;0-2x&quot;&#10;ELSEIF [Calculation_6729592193171463] &lt; 6 THEN &quot;3-5x&quot;&#10;ELSEIF [Calculation_6729592193171463] &lt; 9 THEN &quot;6-8x&quot;&#10;ELSEIF [Calculation_6729592193171463] &lt; 12 THEN &quot;9-11x&quot;&#10;ELSEIF [Calculation_6729592193171463] &lt; 15 THEN &quot;12-14x&quot;&#10;ELSE &quot;15x+&quot;&#10;END' />
      </column>
      <column caption='Segment Customer Count' datatype='integer' name='[Calculation_0347477554065429]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([CustomerId])' />
      </column>
      <column caption='Segment Inclusion Flag' datatype='boolean' name='[Calculation_0347477554294806]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &quot;All Segments&quot; THEN&#10;    TRUE&#10;ELSE&#10;    COUNTD([CustomerId]) &gt;= 50&#10;END' />
      </column>
      <column caption='Exposure by Cell' datatype='integer' name='[Calculation_0913932254609408]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_0347477378277392], [Calculation_6729592076996609] : SUM([Home loan Balance]) }' />
      </column>
      <column caption='Max Exposure per Leverage' datatype='integer' name='[Calculation_0913932254707713]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_0347477378277392] : MAX([Calculation_0913932254609408]) }' />
      </column>
      <column caption='Is Ridge Cell' datatype='boolean' name='[Calculation_0913932254797826]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_0913932254609408] = [Calculation_0913932254707713]' />
      </column>
      <column caption='Liquidity Index' datatype='integer' name='[Calculation_0913932255473667]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_6729592076996609] = &quot;&lt; 1 Month&quot; THEN 1&#10;ELSEIF [Calculation_6729592076996609] = &quot;1–3 Months&quot; THEN 2&#10;ELSEIF [Calculation_6729592076996609] = &quot;3–6 Months&quot; THEN 3&#10;ELSEIF [Calculation_6729592076996609] = &quot;6+ Months&quot; THEN 4&#10;END' />
      </column>
      <column caption='Leverage band index' datatype='integer' name='[Calculation_0913932255543300]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0347477378277392] = &quot;0–2x&quot; THEN 1&#10;ELSEIF [Calculation_0347477378277392] = &quot;3–5x&quot; THEN 2&#10;ELSEIF [Calculation_0347477378277392] = &quot;6–8x&quot; THEN 3&#10;ELSEIF [Calculation_0347477378277392] = &quot;9–11x&quot; THEN 4&#10;ELSEIF [Calculation_0347477378277392] = &quot;15x+&quot; THEN 5&#10;END' />
      </column>
      <column caption='Age Bracket' datatype='string' name='[Calculation_1811818870714368]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt;= 22 THEN &quot;18-22&quot;&#10;ELSEIF [Age] &lt;= 27 THEN &quot;23-27&quot;&#10;ELSEIF [Age] &lt;= 32 THEN &quot;28-32&quot;&#10;ELSEIF [Age] &lt;= 37 THEN &quot;33-37&quot;&#10;ELSEIF [Age] &lt;= 42 THEN &quot;38-42&quot;&#10;ELSEIF [Age] &lt;= 47 THEN &quot;43-47&quot;&#10;ELSEIF [Age] &lt;= 52 THEN &quot;48-52&quot;&#10;ELSEIF [Age] &lt;= 57 THEN &quot;53-57&quot;&#10;ELSEIF [Age] &lt;= 62 THEN &quot;58-62&quot;&#10;ELSEIF [Age] &lt;= 67 THEN &quot;63-67&quot;&#10;ELSE &quot;68+&quot;&#10;END' />
      </column>
      <column caption='Mortgage Customer ID' datatype='integer' name='[Calculation_4524936422486017]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [HasHome Loan] = 1 THEN [CustomerId] END' />
      </column>
      <column caption='Total Mortgage Customers (State)' datatype='integer' name='[Calculation_4524936422596610]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [State] :&#10;    COUNTD([CustomerId])&#10;}' />
      </column>
      <column caption='Good Mortgage Customer by State' datatype='integer' name='[Calculation_4524936423317507]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([CustomerId])' />
      </column>
      <column caption='Good Mortgage Customers (State)' datatype='integer' name='[Calculation_4524936424562693]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;    IF [Calculation_4524936425017350] THEN [CustomerId] END&#10;)' />
      </column>
      <column caption='Good Mortgage Customer' datatype='boolean' name='[Calculation_4524936425017350]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[HasHome Loan] = 1&#10;AND ([Calculation_6729592075571200] = &quot;High&quot; OR [Calculation_6729592075571200] = &quot;Very High&quot;)&#10;AND ([Calculation_6729592076996609] = &quot;3–6 Months&quot; OR [Calculation_6729592076996609] = &quot;6+ Months&quot;)&#10;AND [DelinquencyFlag] = 0' />
      </column>
      <column caption='% Good Mortgage Customers' datatype='real' name='[Calculation_4524936426328071]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_4524936426582024]&#10;/&#10;[Calculation_4524936426782729]' />
      </column>
      <column caption='Good Mortgage Customer Count' datatype='integer' name='[Calculation_4524936426582024]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;    IF [Calculation_4524936425017350] THEN [CustomerId] END&#10;)' />
      </column>
      <column caption='Mortgage Customer Count' datatype='integer' name='[Calculation_4524936426782729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([CustomerId])' />
      </column>
      <column caption='Lending Exposure' datatype='string' name='[Calculation_5779406891675648]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [HasHome Loan] = 1&#10;OR [HasCrCard] = 1&#10;OR [HasCarLoan] = 1&#10;THEN &quot;Yes&quot;&#10;ELSE &quot;No&quot;&#10;END' />
      </column>
      <column caption='Lending Product' datatype='string' name='[Calculation_5779406893178881]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [HasHome Loan] = 1 THEN &quot;Home Loan&quot;&#10;ELSEIF [HasCrCard] = 1 THEN &quot;Credit Card&quot;&#10;ELSEIF [HasCarLoan] = 1 THEN &quot;Car Loan&quot;&#10;ELSE &quot;No Lending&quot;&#10;END' />
      </column>
      <column caption='Credit Score Health' datatype='string' name='[Calculation_6729592075571200]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [CreditScore] &lt; 500 THEN &quot;Very Poor&quot;&#10;ELSEIF [CreditScore] &lt; 650 THEN &quot;Poor&quot;&#10;ELSEIF [CreditScore] &lt; 750 THEN &quot;Medium&quot;&#10;ELSEIF [CreditScore] &lt; 850 THEN &quot;High&quot;&#10;ELSE &quot;Very High&quot;&#10;END' />
      </column>
      <column caption='Liquidity Buffer' datatype='string' name='[Calculation_6729592076996609]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &lt; 1 THEN &apos;&lt; 1 Month&apos;&#10;ELSEIF ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &gt;= 1 AND ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &lt; 3 THEN &apos;1-3 Months&apos;&#10;ELSEIF ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &gt;= 3 AND ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &lt; 6 THEN &apos;3-6 Months&apos;&#10;ELSEIF ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &gt;= 6 THEN &apos;6+ Months&apos;&#10;END' />
      </column>
      <column caption='Debt to Income Proxy' datatype='real' name='[Calculation_6729592080130050]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Home loan Balance] + [CarLoanBalance] + [Credit Balance Amt]) / [EstimatedSalary]' />
      </column>
      <column caption='Leverage' datatype='real' name='[Calculation_6729592193171463]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Home loan Balance]+[Credit Balance Amt]+[CarLoanBalance])/[EstimatedSalary]' />
      </column>
      <column caption='Delinquency Rate' datatype='real' name='[Calculation_6729592197292044]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([DelinquencyFlag]) / COUNT([CustomerId])' />
      </column>
      <column caption='Car Loan Balance' datatype='integer' name='[CarLoanBalance]' role='measure' type='quantitative' />
      <column caption='Checking Balance' datatype='integer' name='[CheckingBalance]' role='measure' type='quantitative' />
      <column caption='Churn Date' datatype='date' name='[ChurnDate]' role='dimension' type='ordinal' />
      <column aggregation='Sum' caption='Churn' datatype='integer' name='[ChurnFlag]' role='dimension' type='ordinal'>
        <aliases>
          <alias key='0' value='Current Customers' />
          <alias key='1' value='Churned Customers' />
        </aliases>
