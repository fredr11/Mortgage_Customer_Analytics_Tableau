            </column>
            <column aggregation='Sum' caption='Home Loan' datatype='integer' name='[HasHome Loan]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
              </aliases>
            </column>
            <column caption='Home Loan Balance' datatype='integer' name='[Home loan Balance]' role='measure' type='quantitative' />
            <column aggregation='Sum' datatype='integer' name='[Industry Risk]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='Low' />
                <alias key='1' value='Medium' />
                <alias key='2' value='High' />
              </aliases>
            </column>
            <column caption='Savings Balance' datatype='integer' name='[SavingsBalance]' role='measure' type='quantitative' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column aggregation='None' caption='Tenure Years' datatype='integer' name='[Tenure (bin)]' role='dimension' type='ordinal'>
