    <worksheet name='High-Risk Mortgage Segments: Risk vs. Exposure'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontsize='11'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run>Relative Delinquency Index vs. Total Home Loan Balance.  Color shows details about Liquidity Buffer.  Size shows number of Customers. Details are shown for Credit Score Health, Liquidity Buffer and Leverage Level. The data only shows customers with home loans and can be filtered by Industry Risk.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Dataset (T32025A3)' name='federated.0hi237i01j10bz194o49j176vj2p' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Parameter 1' datatype='real' name='[Parameter 1]' param-domain-type='any' role='measure' type='quantitative' value='1.0'>
              <calculation class='tableau' formula='1.0' />
            </column>
            <column alias='≥ 50 Customers' caption='Segment View Mode' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Segments ≥ 50 Customers&quot;'>
              <calculation class='tableau' formula='&quot;Segments ≥ 50 Customers&quot;' />
              <aliases>
                <alias key='&quot;Segments ≥ 50 Customers&quot;' value='≥ 50 Customers' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0hi237i01j10bz194o49j176vj2p'>
            <column datatype='integer' name='[Age]' role='measure' type='quantitative' />
            <column caption='Relative Delinquency Index' datatype='real' name='[Calculation_0347477257351172]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_6729592197292044]&#10;/&#10;TOTAL([Calculation_6729592197292044])'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Leverage Level' datatype='string' name='[Calculation_0347477378277392]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_6729592193171463] &lt; 3 THEN &quot;0-2x&quot;&#10;ELSEIF [Calculation_6729592193171463] &lt; 6 THEN &quot;3-5x&quot;&#10;ELSEIF [Calculation_6729592193171463] &lt; 9 THEN &quot;6-8x&quot;&#10;ELSEIF [Calculation_6729592193171463] &lt; 12 THEN &quot;9-11x&quot;&#10;ELSEIF [Calculation_6729592193171463] &lt; 15 THEN &quot;12-14x&quot;&#10;ELSE &quot;15x+&quot;&#10;END' />
            </column>
            <column caption='Segment Inclusion Flag' datatype='boolean' name='[Calculation_0347477554294806]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &quot;All Segments&quot; THEN&#10;    TRUE&#10;ELSE&#10;    COUNTD([CustomerId]) &gt;= 50&#10;END' />
            </column>
            <column caption='Age Bracket' datatype='string' name='[Calculation_1811818870714368]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Age] &lt;= 22 THEN &quot;18-22&quot;&#10;ELSEIF [Age] &lt;= 27 THEN &quot;23-27&quot;&#10;ELSEIF [Age] &lt;= 32 THEN &quot;28-32&quot;&#10;ELSEIF [Age] &lt;= 37 THEN &quot;33-37&quot;&#10;ELSEIF [Age] &lt;= 42 THEN &quot;38-42&quot;&#10;ELSEIF [Age] &lt;= 47 THEN &quot;43-47&quot;&#10;ELSEIF [Age] &lt;= 52 THEN &quot;48-52&quot;&#10;ELSEIF [Age] &lt;= 57 THEN &quot;53-57&quot;&#10;ELSEIF [Age] &lt;= 62 THEN &quot;58-62&quot;&#10;ELSEIF [Age] &lt;= 67 THEN &quot;63-67&quot;&#10;ELSE &quot;68+&quot;&#10;END' />
            </column>
            <column caption='Lending Product' datatype='string' name='[Calculation_5779406893178881]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [HasHome Loan] = 1 THEN &quot;Home Loan&quot;&#10;ELSEIF [HasCrCard] = 1 THEN &quot;Credit Card&quot;&#10;ELSEIF [HasCarLoan] = 1 THEN &quot;Car Loan&quot;&#10;ELSE &quot;No Lending&quot;&#10;END' />
            </column>
            <column caption='Credit Score Health' datatype='string' name='[Calculation_6729592075571200]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [CreditScore] &lt; 500 THEN &quot;Very Poor&quot;&#10;ELSEIF [CreditScore] &lt; 650 THEN &quot;Poor&quot;&#10;ELSEIF [CreditScore] &lt; 750 THEN &quot;Medium&quot;&#10;ELSEIF [CreditScore] &lt; 850 THEN &quot;High&quot;&#10;ELSE &quot;Very High&quot;&#10;END' />
            </column>
            <column caption='Liquidity Buffer' datatype='string' name='[Calculation_6729592076996609]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &lt; 1 THEN &apos;&lt; 1 Month&apos;&#10;ELSEIF ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &gt;= 1 AND ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &lt; 3 THEN &apos;1-3 Months&apos;&#10;ELSEIF ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &gt;= 3 AND ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &lt; 6 THEN &apos;3-6 Months&apos;&#10;ELSEIF ([SavingsBalance] + [CheckingBalance]) / ([EstimatedSalary] / 12) &gt;= 6 THEN &apos;6+ Months&apos;&#10;END' />
            </column>
            <column caption='Leverage' datatype='real' name='[Calculation_6729592193171463]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Home loan Balance]+[Credit Balance Amt]+[CarLoanBalance])/[EstimatedSalary]' />
            </column>
            <column caption='Delinquency Rate' datatype='real' name='[Calculation_6729592197292044]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([DelinquencyFlag]) / COUNT([CustomerId])' />
            </column>
            <column caption='Car Loan Balance' datatype='integer' name='[CarLoanBalance]' role='measure' type='quantitative' />
            <column caption='Checking Balance' datatype='integer' name='[CheckingBalance]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Credit Balance Amt]' role='measure' type='quantitative' />
            <column caption='Credit Score' datatype='integer' name='[CreditScore]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Customer Id' datatype='integer' name='[CustomerId]' role='dimension' type='ordinal' />
            <column aggregation='Sum' caption='Delinquency Flag' datatype='integer' name='[DelinquencyFlag]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
              </aliases>
            </column>
            <column caption='Estimated Salary' datatype='integer' name='[EstimatedSalary]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Has Car Loan' datatype='integer' name='[HasCarLoan]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
              </aliases>
            </column>
            <column aggregation='Sum' caption='Has Cr Card' datatype='integer' name='[HasCrCard]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
              </aliases>
            </column>
            <column aggregation='Sum' caption='Home Loan' datatype='integer' name='[HasHome Loan]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
              </aliases>
            </column>
            <column caption='Home Loan Balance' datatype='integer' name='[Home loan Balance]' role='measure' type='quantitative' />
            <column aggregation='Sum' datatype='integer' name='[Industry Risk]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='Low' />
                <alias key='1' value='Medium' />
                <alias key='2' value='High' />
              </aliases>
            </column>
            <column caption='Savings Balance' datatype='integer' name='[SavingsBalance]' role='measure' type='quantitative' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column aggregation='None' caption='Tenure Years' datatype='integer' name='[Tenure (bin)]' role='dimension' type='ordinal'>
              <calculation class='bin' decimals='0' formula='[Tenure]' peg='0' size='2' />
              <aliases>
                <alias key='0' value='0-1' />
                <alias key='1' value='2-3' />
                <alias key='2' value='4-5' />
                <alias key='3' value='6-7' />
                <alias key='4' value='8-9' />
              </aliases>
            </column>
            <column datatype='integer' name='[Tenure]' role='measure' type='quantitative' />
            <column-instance column='[CustomerId]' derivation='Count' name='[cnt:CustomerId:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0347477378277392]' derivation='None' name='[none:Calculation_0347477378277392:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_5779406893178881]' derivation='None' name='[none:Calculation_5779406893178881:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_6729592075571200]' derivation='None' name='[none:Calculation_6729592075571200:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_6729592076996609]' derivation='None' name='[none:Calculation_6729592076996609:nk]' pivot='key' type='nominal' />
            <column-instance column='[HasHome Loan]' derivation='None' name='[none:HasHome Loan:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Industry Risk]' derivation='None' name='[none:Industry Risk:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Home loan Balance]' derivation='Sum' name='[sum:Home loan Balance:qk]' pivot='key' type='quantitative' />
