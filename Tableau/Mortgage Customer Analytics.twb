              <table-calc ordering-type='Rows' />
            </column-instance>
            <column-instance column='[Calculation_0347477554294806]' derivation='User' name='[usr:Calculation_0347477554294806:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_6729592197292044]' derivation='User' name='[usr:Calculation_6729592197292044:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
