            </column>
            <column caption='Estimated Salary' datatype='integer' name='[EstimatedSalary]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Has Car Loan' datatype='integer' name='[HasCarLoan]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
              </aliases>
            </column>
            <column aggregation='Sum' caption='Has Cr Card' datatype='integer' name='[HasCrCard]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='No' />
                <alias key='1' value='Yes' />
