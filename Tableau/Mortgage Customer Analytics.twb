            </column>
            <column caption='Savings Balance' datatype='integer' name='[SavingsBalance]' role='measure' type='quantitative' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column aggregation='None' caption='Tenure Years' datatype='integer' name='[Tenure (bin)]' role='dimension' type='ordinal'>
              <calculation class='bin' decimals='0' formula='[Tenure]' peg='0' size='2' />
              <aliases>
                <alias key='0' value='0-1' />
                <alias key='1' value='2-3' />
                <alias key='2' value='4-5' />
                <alias key='3' value='6-7' />
                <alias key='4' value='8-9' />
